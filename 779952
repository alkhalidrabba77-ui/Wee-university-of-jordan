/* ── Generic Form Page ── */
function FormPage({title,icon,fields,items,setItems,toast,statusOpts=[]}){
  const [show,setShow]=useState(false);
  const [form,setForm]=useState({});
  const [filter,setFilter]=useState('all');
  const set=(k,v)=>setForm(p=>({...p,[k]:v}));
  const submit=()=>{
    const req=fields.find(f=>f.req&&!form[f.key]);
    if(req)return toast(`الحقل "${req.label}" مطلوب`,'warning');
    setItems(p=>[{id:Date.now(),...form,status:statusOpts[0]||'قيد المعالجة',date:nowStr()},...p]);
    setForm({});setShow(false);toast('تم الإرسال بنجاح ✓','success');
  };
