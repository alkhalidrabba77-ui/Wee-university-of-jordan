/* ── Generic Form Page ── */
function FormPage({title,icon,fields,items,setItems,toast,statusOpts=[]}){
  const [show,setShow]=useState(false);
  const [form,setForm]=useState({});
  const [filter,setFilter]=useState('all');
  const set=(k,v)=>setForm(p=>({...p,[k]:v}));
  const submit=()=>{
    const req=fields.find(f=>f.req&&!form[f.key]);
    if(req)return toast(`الحقل "${req.label}" مطلوب`,'warning');
    setItems(p=>[{id:Date.now(),...form,status:statusOpts[0]||'قيد المعالجة',date:nowStr()},...p]);
    setForm({});setShow(false);toast('تم الإرسال بنجاح ✓','success');
  };
  const SC={'قيد المعالجة':'#f59e0b','مكتمل':'#22c55e','مغلق':'#64748b','عاجل':'#ef4444','مجاب':'#22c55e','قيد المراجعة':'#38bdf8','مؤجل':'#a78bfa','مجدول':'#f59e0b','جارٍ':'#38bdf8','مخطط':'#a78bfa'};
  const filtered=filter==='all'?items:items.filter(i=>i.status===filter);
  return(
    <div style={{padding:22,height:'100%',display:'flex',flexDirection:'column',gap:14}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:12}}>
