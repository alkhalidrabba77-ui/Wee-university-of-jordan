  const [maintenance,setMaintenance]=useState([{id:1,title:'صيانة مكيف الغرفة 201',desc:'المكيف لا يعمل',category:'كهربائي',priority:'عاجل',status:'قيد المعالجة',date:nowStr()}]);
  const [community,setCommunity]=useState([{id:1,title:'ورشة تدريب الطلاب الجامعيين',desc:'برنامج تدريب طلاب الجامعة',category:'تدريب',priority:'عادي',status:'مخطط',date:nowStr()}]);
  const [goals,setGoals]=useState([{id:1,title:'ريادة البحث العلمي التطبيقي',desc:'أن يكون المركز مرجعاً بحثياً وطنياً',category:'استراتيجي',priority:'عالي',status:'جارٍ',date:nowStr()}]);

  useEffect(()=>{const t=setInterval(()=>setTime(new Date()),1000);return()=>clearInterval(t);},[]);

  const toast=(msg,type='info')=>setToastState({msg,type});
  const unread=notifs.filter(n=>!n.read).length;
  const allNodes=flatTree(org);
  const searchResults=searchQ?allNodes.filter(n=>n.name?.includes(searchQ)||n.role?.includes(searchQ)):[];

  const toggleFS=()=>{
    if(!fullscreen){document.documentElement.requestFullscreen&&document.documentElement.requestFullscreen();}
    else{document.exitFullscreen&&document.exitFullscreen();}
    setFullscreen(!fullscreen);
  };

  const exportData=()=>{
    const d=JSON.stringify({org,timestamp:new Date().toISOString()},null,2);
    const b=new Blob([d],{type:'application/json'});
    const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='wee-center-data.json';a.click();
    toast('تم التصدير ✓','success');
  };

  const renderPage=()=>{
    switch(page){
      case 'dash': return <Dashboard org={org} notifications={notifs} centerLogo={centerLogo}/>;
      case 'org': return <OrgPage org={org} setOrg={setOrg} toast={toast}/>;
      case 'researchers': return <ResearchersPage toast={toast}/>;
      case 'vision': return <VisionPage toast={toast} centerLogo={centerLogo}/>;
      case 'complaints': return <FormPage title="صندوق الشكاوي" icon="📨" fields={[{key:'title',label:'عنوان الشكوى',req:true},{key:'desc',label:'تفاصيل الشكوى',type:'textarea'},{key:'category',label:'التصنيف',type:'select',opts:['تقني','إداري','مالي','بشري','أخرى']},{key:'priority',label:'الأولوية',type:'select',opts:['عادي','متوسط','عاجل']}]} items={complaints} setItems={setComplaints} toast={toast} statusOpts={['قيد المعالجة','مكتمل','مغلق','عاجل']}/>;
      case 'inquiries': return <FormPage title="الاستفسارات" icon="❓" fields={[{key:'title',label:'موضوع الاستفسار',req:true},{key:'desc',label:'تفاصيل الاستفسار',type:'textarea'},{key:'category',label:'القسم',type:'select',opts:['إداري','مالي','تقني','بشري','أكاديمي']}]} items={inquiries} setItems={setInquiries} toast={toast} statusOpts={['قيد المراجعة','مجاب','مؤجل','مغلق']}/>;
      case 'satisfaction': return <SatisfactionPage toast={toast}/>;
      case 'maintenance': return <FormPage title="طلبات الصيانة" icon="🔧" fields={[{key:'title',label:'عنوان الطلب',req:true},{key:'desc',label:'وصف المشكلة',type:'textarea'},{key:'category',label:'نوع الصيانة',type:'select',opts:['كهربائي','ميكانيكي','تقني','مدني','أخرى']},{key:'priority',label:'الأولوية',type:'select',opts:['عادي','عاجل','طارئ']}]} items={maintenance} setItems={setMaintenance} toast={toast} statusOpts={['قيد المعالجة','مجدول','مكتمل','عاجل']}/>;
      case 'community': return <FormPage title="خدمة المجتمع المحلي" icon="🌍" fields={[{key:'title',label:'عنوان المبادرة',req:true},{key:'desc',label:'وصف المبادرة',type:'textarea'},{key:'category',label:'النوع',type:'select',opts:['تدريب','توعية','شراكة','تطوع','أخرى']}]} items={community} setItems={setCommunity} toast={toast} statusOpts={['مخطط','جارٍ','مكتمل','مؤجل']}/>;
      case 'challenges': return <ChallengesPage toast={toast}/>;
      case 'improvement': return <ImprovementPage toast={toast}/>;
      case 'targets': return <TargetsPage/>;
      case 'goals': return <FormPage title="الأهداف المرجوة" icon="⭐" fields={[{key:'title',label:'الهدف',req:true},{key:'desc',label:'توصيف الهدف',type:'textarea'},{key:'category',label:'التصنيف',type:'select',opts:['استراتيجي','بحثي','تشغيلي','تنموي']},{key:'priority',label:'الأهمية',type:'select',opts:['عالي','متوسط','منخفض']}]} items={goals} setItems={setGoals} toast={toast} statusOpts={['مخطط','جارٍ','مكتمل','مؤجل']}/>;
      case 'quality': return <QualityPage/>;
      case 'files': return <FilesPage toast={toast}/>;
      case 'transfer': return <TransferPage org={org} toast={toast}/>;
      case 'social': return <SocialPage toast={toast}/>;
      case 'chatbot': return <ChatbotPage toast={toast}/>;
      case 'conduct': return <ConductPage/>;
      case 'integrity': return <IntegrityPage/>;
      case 'voice': return <VoicePage toast={toast}/>;
      case 'aichats': return <AIChatsPage toast={toast}/>;
      case 'settings': return <SettingsPage toast={toast} centerLogo={centerLogo} setCenterLogo={setCenterLogo}/>;
      default: return <Dashboard org={org} notifications={notifs} centerLogo={centerLogo}/>;
    }
  };

  const curPage=NAV.flatMap(s=>s.items).find(n=>n.id===page);

  return(
    <div dir="rtl" style={{display:'flex',height:'100vh',color:'#e2e8f0',overflow:'hidden',position:'relative',background:'#030b18'}}>
      {/* SIDEBAR */}
      <div className="sidebar" style={{width:sidebarOpen?242:0,minWidth:sidebarOpen?242:0,background:'rgba(3,9,20,.97)',borderLeft:'1px solid rgba(26,122,138,.14)',transition:'all .3s ease',overflow:'hidden',display:'flex',flexDirection:'column',zIndex:100,backdropFilter:'blur(20px)'}}>
        <div style={{padding:'16px 14px',borderBottom:'1px solid rgba(26,122,138,.11)',flexShrink:0}}>
          <div style={{display:'flex',alignItems:'center',gap:10}}>
            <div style={{width:40,height:40,borderRadius:12,background:'linear-gradient(135deg,#0e7490,#38bdf8)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:20,flexShrink:0,overflow:'hidden'}}>
              {centerLogo?<img src={centerLogo} alt="" style={{width:'100%',height:'100%',objectFit:'contain',padding:4}}/>:'💧'}
            </div>
            <div>
              <div style={{color:'#38bdf8',fontWeight:900,fontSize:12,lineHeight:1.3,whiteSpace:'nowrap'}}>مركز المياه والبيئة</div>
              <div style={{color:'#334155',fontSize:10}}>والطاقة — الجامعة الأردنية</div>
            </div>
          </div>
        </div>
        <div ref={sidebarScrollRef} style={{flex:1,overflowY:'auto',padding:'6px 0'}}>
          {NAV.map(sec=>(
            <div key={sec.sec}>
              <span className="ss-lbl">{sec.sec}</span>
              {sec.items.map(({id,label,e})=>(
                <div key={id} className={`sl ${page===id?'act':''}`} onClick={()=>goTo(id)} style={{display:'flex',alignItems:'center',gap:10,padding:'10px 14px',color:page===id?'#38bdf8':'#64748b',fontSize:13,fontWeight:page===id?700:400}}>
                  <span style={{fontSize:16,flexShrink:0}}>{e}</span>
                  <span style={{whiteSpace:'nowrap'}}>{label}</span>
                </div>
              ))}
            </div>
          ))}
        </div>
        <div style={{padding:'9px 14px',borderTop:'1px solid rgba(26,122,138,.1)',fontSize:10,color:'#1e3a5f'}}>
          <div>نظام الإدارة الرقمية المتكامل</div>
          <div style={{color:'#0e7490'}}>WEE Center v3.1 © 2025 — الجامعة الأردنية</div>
        </div>
      </div>

      {/* MAIN */}
      <div style={{flex:1,display:'flex',flexDirection:'column',overflow:'hidden'}}>
        {/* HEADER */}
        <div style={{height:58,background:'rgba(3,9,20,.97)',borderBottom:'1px solid rgba(26,122,138,.11)',display:'flex',alignItems:'center',justifyContent:'space-between',padding:'0 12px',flexShrink:0,backdropFilter:'blur(16px)',zIndex:90}}>
          <div style={{display:'flex',alignItems:'center',gap:10}}>
            <button onClick={()=>setSidebarOpen(!sidebarOpen)} style={{background:'rgba(56,189,248,.07)',border:'1px solid rgba(56,189,248,.16)',borderRadius:8,padding:'7px 10px',cursor:'pointer',color:'#38bdf8',fontSize:17,fontFamily:'Tajawal,sans-serif'}}>☰</button>
            {curPage&&<div style={{color:'#e2e8f0',fontWeight:700,fontSize:14,display:'flex',gap:7,alignItems:'center'}}>
              <span style={{fontSize:17}}>{curPage.e}</span>
              <span style={{display:'none'}}>{curPage.label}</span>
            </div>}
          </div>
          <div style={{display:'flex',alignItems:'center',gap:7}}>
            {/* Clock */}
            <div style={{display:'flex',alignItems:'center',gap:5,background:'rgba(56,189,248,.06)',border:'1px solid rgba(56,189,248,.14)',borderRadius:9,padding:'5px 10px',flexShrink:0}}>
              <span style={{fontSize:13}}>🕐</span>
              <span style={{color:'#38bdf8',fontWeight:800,fontSize:13,minWidth:62,fontVariantNumeric:'tabular-nums'}}>{time.toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}</span>
            </div>
            {/* Search */}
            <div style={{position:'relative'}}>
              <button onClick={()=>setShowSearch(!showSearch)} style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(255,255,255,.07)',borderRadius:9,padding:'7px 10px',cursor:'pointer',color:'#64748b',fontSize:16,fontFamily:'Tajawal,sans-serif'}}>🔍</button>
              {showSearch&&(
                <div style={{position:'absolute',top:'112%',left:0,background:'#060f1e',border:'1px solid rgba(56,189,248,.22)',borderRadius:12,padding:12,width:260,zIndex:200,boxShadow:'0 20px 60px rgba(0,0,0,.7)'}}>
                  <input autoFocus value={searchQ} onChange={e=>setSearchQ(e.target.value)} placeholder="بحث عن موظف أو دور..." className="inp" style={{marginBottom:searchResults.length?9:0,fontSize:13}}/>
                  {searchResults.map(n=>(
                    <div key={n.id} onClick={()=>{setPage('org');setShowSearch(false);setSearchQ('');}} style={{display:'flex',gap:9,padding:'8px 4px',cursor:'pointer',borderBottom:'1px solid rgba(255,255,255,.04)',alignItems:'center'}}>
                      <span style={{fontSize:15}}>👤</span>
                      <div><div style={{color:'#e2e8f0',fontSize:13,fontWeight:600}}>{n.role}</div><div style={{color:'#64748b',fontSize:11}}>{n.name||'شاغر'}</div></div>
                    </div>
                  ))}
                  {searchQ&&!searchResults.length&&<div style={{color:'#475569',fontSize:12,textAlign:'center',padding:8}}>لا توجد نتائج</div>}
                </div>
              )}
            </div>
            {/* Notifs */}
            <div style={{position:'relative'}}>
              <button onClick={()=>setShowNotifs(!showNotifs)} style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(255,255,255,.07)',borderRadius:9,padding:'7px 10px',cursor:'pointer',color:'#64748b',position:'relative',fontSize:16,fontFamily:'Tajawal,sans-serif'}}>
                🔔
                {unread>0&&<span className="bdg">{unread}</span>}
              </button>
              {showNotifs&&(
                <div style={{position:'absolute',top:'112%',left:0,background:'#060f1e',border:'1px solid rgba(56,189,248,.2)',borderRadius:13,width:295,zIndex:200,boxShadow:'0 20px 60px rgba(0,0,0,.7)',overflow:'hidden'}}>
                  <div style={{padding:'12px 14px',borderBottom:'1px solid rgba(255,255,255,.05)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                    <span style={{color:'#38bdf8',fontWeight:800,fontSize:14}}>🔔 الإشعارات</span>
                    <button onClick={()=>{setNotifs(p=>p.map(n=>({...n,read:true})));toast('تم تحديد الكل مقروءاً ✓','success');}} style={{background:'rgba(56,189,248,.1)',border:'none',borderRadius:8,padding:'4px 9px',cursor:'pointer',color:'#38bdf8',fontSize:12,fontFamily:'Tajawal,sans-serif'}}>تحديد الكل</button>
                  </div>
                  <div style={{maxHeight:250,overflowY:'auto'}}>
                    {notifs.map(n=>(
                      <div key={n.id} onClick={()=>setNotifs(p=>p.map(nn=>nn.id===n.id?{...nn,read:true}:nn))} style={{padding:'11px 14px',borderBottom:'1px solid rgba(255,255,255,.03)',background:n.read?'transparent':'rgba(56,189,248,.05)',cursor:'pointer',display:'flex',gap:9,alignItems:'flex-start'}}>
                        <div style={{width:7,height:7,borderRadius:'50%',background:n.read?'transparent':'#38bdf8',marginTop:5,flexShrink:0}}/>
                        <div style={{flex:1}}><div style={{color:n.read?'#475569':'#e2e8f0',fontSize:12.5,lineHeight:1.5}}>{n.msg}</div><div style={{color:'#334155',fontSize:11,marginTop:2}}>{n.time}</div></div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
            <button onClick={exportData} style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(255,255,255,.07)',borderRadius:9,padding:'7px 10px',cursor:'pointer',color:'#64748b',fontSize:16,fontFamily:'Tajawal,sans-serif'}} title="تصدير">⬇️</button>
            <button onClick={toggleFS} style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(255,255,255,.07)',borderRadius:9,padding:'7px 10px',cursor:'pointer',color:'#64748b',fontSize:15,fontFamily:'Tajawal,sans-serif'}} title="ملء الشاشة">{fullscreen?'⊡':'⊞'}</button>
          </div>
        </div>
        {/* PAGE CONTENT */}
        <div style={{flex:1,overflow:'hidden'}} onClick={()=>{if(showNotifs)setShowNotifs(false);if(showSearch)setShowSearch(false);}}>
          {renderPage()}
        </div>
      </div>
      <Toast t={toastState} onClose={()=>setToastState(null)}/>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
