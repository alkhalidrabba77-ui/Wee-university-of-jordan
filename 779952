/* ── Files ── */
function FilesPage({toast}){
  const [files,setFiles]=useState(INIT_FILES);
  const [folder,setFolder]=useState('الكل');
  const [search,setSearch]=useState('');
  const [view,setView]=useState('grid');
  const [selected,setSelected]=useState([]);
  const [preview,setPreview]=useState(null);
  const uploadRef=useRef();
  const handleUpload=e=>{
    const fs=Array.from(e.target.files);
    if(!fs.length)return;
    const newFs=fs.map(f=>({id:uid(),name:f.name,size:f.size,folder:folder==='الكل'?'وثائق إدارية':folder,date:nowStr(),preview:f.type.startsWith('image/')?URL.createObjectURL(f):null}));
    setFiles(p=>[...newFs,...p]);
    toast(`تم رفع ${fs.length} ملف ✓`,'success');
    e.target.value='';
  };
  const toggleSel=id=>setSelected(p=>p.includes(id)?p.filter(x=>x!==id):[...p,id]);
  const delSelected=()=>{setFiles(p=>p.filter(f=>!selected.includes(f.id)));toast(`تم حذف ${selected.length} ملف`,'error');setSelected([]);};
  const filtered=files.filter(f=>(folder==='الكل'||f.folder===folder)&&(f.name.toLowerCase().includes(search.toLowerCase())||!search));
  return(
    <div style={{padding:22,height:'100%',display:'flex',flexDirection:'column',gap:12}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:12}}>
        <div><h1 style={{color:'#38bdf8',fontSize:20,fontWeight:900}}>📁 إدارة الملفات</h1><p style={{color:'#64748b',fontSize:13}}>{files.length} ملف • {fmtSize(files.reduce((a,f)=>a+f.size,0))} إجمالي</p></div>
        <div style={{display:'flex',gap:9,flexWrap:'wrap'}}>
          {selected.length>0&&<button className="rb" onClick={delSelected} style={{padding:'8px 14px',fontSize:13}}>🗑️ حذف ({selected.length})</button>}
          <button className="eb" onClick={()=>{const d=JSON.stringify(files.map(f=>({name:f.name,size:fmtSize(f.size),folder:f.folder,date:f.date})),null,2);const b=new Blob([d],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='files-list.json';a.click();toast('تم التصدير ✓','success');}} style={{padding:'8px 14px',fontSize:13}}>⬇️ تصدير</button>
          <button className="gb" onClick={()=>uploadRef.current?.click()} style={{padding:'8px 14px',fontSize:13}}>⬆️ رفع ملفات</button>
          <input ref={uploadRef} type="file" multiple style={{display:'none'}} onChange={handleUpload}/>
        </div>
      </div>
      <div style={{display:'flex',gap:9,flexWrap:'wrap',alignItems:'center'}}>
        <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="🔍 بحث في الملفات..." style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(56,189,248,.2)',borderRadius:10,padding:'8px 14px',color:'#e2e8f0',fontSize:13,flex:1,minWidth:160,fontFamily:'Tajawal,sans-serif'}}/>
        <select className="sel" style={{width:'auto',padding:'8px 12px',fontSize:13}} value={folder} onChange={e=>setFolder(e.target.value)}>
          {FOLDERS.map(f=><option key={f} value={f}>{f}</option>)}
        </select>
        <div style={{display:'flex',gap:4}}>
          {[['⊞','grid'],['☰','list']].map(([e,v])=>(
            <button key={v} onClick={()=>setView(v)} style={{background:view===v?'rgba(56,189,248,.2)':'rgba(255,255,255,.04)',border:`1px solid ${view===v?'rgba(56,189,248,.4)':'rgba(255,255,255,.1)'}`,borderRadius:8,padding:'7px 11px',cursor:'pointer',color:view===v?'#38bdf8':'#64748b',fontSize:16,fontFamily:'Tajawal,sans-serif'}}>{e}</button>
          ))}
        </div>
      </div>
      <div style={{flex:1,overflowY:'auto'}}>
        {filtered.length===0&&<div style={{textAlign:'center',color:'#475569',marginTop:60}}>📭<div style={{fontSize:14,marginTop:12}}>لا توجد ملفات</div></div>}
        {view==='grid'?(
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(135px,1fr))',gap:11}}>
            {filtered.map(f=>{
              const isSel=selected.includes(f.id);
              return(
                <div key={f.id} className="fc" style={{border:`2px solid ${isSel?'#38bdf8':'rgba(26,122,138,.15)'}`,background:isSel?'rgba(56,189,248,.1)':undefined,position:'relative'}}>
                  <input type="checkbox" checked={isSel} onChange={()=>toggleSel(f.id)} style={{position:'absolute',top:7,right:7,accentColor:'#38bdf8'}}/>
                  {f.preview?<img src={f.preview} alt={f.name} style={{width:58,height:58,objectFit:'cover',borderRadius:8}}/>
                  :<div style={{fontSize:38}}>{getFI(f.name)}</div>}
                  <div style={{color:'#e2e8f0',fontSize:11,fontWeight:600,wordBreak:'break-all',lineHeight:1.4}}>{f.name}</div>
                  <div style={{color:'#475569',fontSize:10}}>{fmtSize(f.size)}</div>
                  <div style={{display:'flex',gap:5}}>
                    <button onClick={()=>setPreview(f)} style={{background:'rgba(168,85,247,.1)',border:'none',borderRadius:6,padding:'3px 7px',cursor:'pointer',color:'#d8b4fe',fontSize:11,fontFamily:'Tajawal,sans-serif'}}>👁️</button>
                    <button onClick={()=>{setFiles(p=>p.filter(x=>x.id!==f.id));toast('تم الحذف','error');}} style={{background:'rgba(239,68,68,.1)',border:'none',borderRadius:6,padding:'3px 7px',cursor:'pointer',color:'#f87171',fontSize:11,fontFamily:'Tajawal,sans-serif'}}>🗑️</button>
                  </div>
                </div>
              );
            })}
          </div>
        ):(
          <div style={{display:'flex',flexDirection:'column',gap:6}}>
            {filtered.map(f=>{
              const isSel=selected.includes(f.id);
              return(
                <div key={f.id} style={{display:'flex',alignItems:'center',gap:12,padding:'11px 14px',background:isSel?'rgba(56,189,248,.08)':'rgba(8,18,36,.7)',border:`1px solid ${isSel?'rgba(56,189,248,.3)':'rgba(26,122,138,.1)'}`,borderRadius:10}}>
                  <input type="checkbox" checked={isSel} onChange={()=>toggleSel(f.id)} style={{accentColor:'#38bdf8'}}/>
                  <span style={{fontSize:20}}>{getFI(f.name)}</span>
                  <span style={{color:'#e2e8f0',fontSize:13,fontWeight:600,flex:1,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{f.name}</span>
                  <span style={{color:'#64748b',fontSize:12,flexShrink:0}}>{fmtSize(f.size)}</span>
                  <span style={{color:'#475569',fontSize:11,flexShrink:0}}>{f.folder}</span>
                  <div style={{display:'flex',gap:5}}>
                    <button onClick={()=>setPreview(f)} style={{background:'rgba(168,85,247,.1)',border:'none',borderRadius:6,padding:'4px 9px',cursor:'pointer',color:'#d8b4fe',fontSize:13,fontFamily:'Tajawal,sans-serif'}}>👁️</button>
                    <button onClick={()=>{setFiles(p=>p.filter(x=>x.id!==f.id));toast('تم الحذف','error');}} style={{background:'rgba(239,68,68,.1)',border:'none',borderRadius:6,padding:'4px 9px',cursor:'pointer',color:'#f87171',fontSize:13,fontFamily:'Tajawal,sans-serif'}}>🗑️</button>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
      {preview&&(
        <Modal onClose={()=>setPreview(null)} title={`👁️ ${preview.name}`} maxW={560}>
          {preview.preview?<img src={preview.preview} alt="" style={{width:'100%',borderRadius:12,marginBottom:16}}/>
          :<div style={{textAlign:'center',padding:40,fontSize:64}}>{getFI(preview.name)}</div>}
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
            {[['الاسم',preview.name],['الحجم',fmtSize(preview.size)],['المجلد',preview.folder],['التاريخ',preview.date]].map(([k,v])=>(
              <div key={k} style={{background:'rgba(56,189,248,.05)',borderRadius:10,padding:'10px 12px'}}>
                <div style={{color:'#64748b',fontSize:11}}>{k}</div>
                <div style={{color:'#e2e8f0',fontWeight:600,fontSize:13}}>{v}</div>
              </div>
            ))}
          </div>
        </Modal>
      )}
    </div>
  );
}

