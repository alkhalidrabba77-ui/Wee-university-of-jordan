  return(
    <div style={{padding:22,height:'100%',overflowY:'auto'}}>
      <div style={{textAlign:'center',marginBottom:26,padding:'26px 20px',background:'linear-gradient(135deg,rgba(14,116,144,.12),rgba(56,189,248,.06))',borderRadius:18,border:'1px solid rgba(56,189,248,.14)',position:'relative',overflow:'hidden'}}>
        <div style={{position:'absolute',top:-20,right:-20,fontSize:110,opacity:.04}}>💧</div>
        {centerLogo?<img src={centerLogo} alt="شعار" style={{height:68,marginBottom:12,objectFit:'contain'}}/>
        :<div style={{width:68,height:68,borderRadius:'50%',background:'linear-gradient(135deg,#0e7490,#38bdf8)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:30,margin:'0 auto 12px'}}>💧</div>}
        <h1 style={{color:'#38bdf8',fontSize:20,fontWeight:900,marginBottom:5}}>مركز المياه والبيئة والطاقة</h1>
        <p style={{color:'#64748b',fontSize:13}}>الجامعة الأردنية — عمّان، الأردن</p>
        <div style={{display:'flex',gap:12,justifyContent:'center',marginTop:14,flexWrap:'wrap'}}>
          {['💧 المياه','🌿 البيئة','⚡ الطاقة','🔬 البحث العلمي'].map(t=>(
