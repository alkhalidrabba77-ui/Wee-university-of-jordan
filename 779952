function VoicePage({toast}){
  const [isRec,setIsRec]=useState(false);
  const [text,setText]=useState('');
  const [translated,setTranslated]=useState('');
  const [lang,setLang]=useState('en');
  const [translating,setTranslating]=useState(false);
  const [history,setHistory]=useState([]);
  const recRef=useRef();
  const startRec=()=>{
    if(!('webkitSpeechRecognition' in window)&&!('SpeechRecognition' in window))return toast('استخدم Chrome أو Edge للتسجيل الصوتي','warning');
    const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    const r=new SR();r.lang='ar-JO';r.continuous=true;r.interimResults=true;
    r.onresult=e=>{let f='';for(let i=e.resultIndex;i<e.results.length;i++)if(e.results[i].isFinal)f+=e.results[i][0].transcript;if(f)setText(p=>p+(p?' ':'')+f);};
    r.onerror=()=>{setIsRec(false);toast('خطأ في التسجيل','error');};
    r.onend=()=>setIsRec(false);
    r.start();recRef.current=r;setIsRec(true);toast('🎙️ جارٍ التسجيل — تكلم الآن','info');
  };
  const stopRec=()=>{recRef.current?.stop();setIsRec(false);toast('تم إيقاف التسجيل ✓','success');};
  const LANGS={en:'الإنجليزية',fr:'الفرنسية',de:'الألمانية',es:'الإسبانية',zh:'الصينية',tr:'التركية',he:'العبرية',ar:'عربية فصحى'};
  const doTranslate=async()=>{
    if(!text.trim())return toast('أدخل نصاً أولاً','warning');
    setTranslating(true);setTranslated('');
    try{const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:800,system:'أنت مترجم محترف. قدم الترجمة مباشرة دون مقدمات.',messages:[{role:'user',content:`ترجم النص التالي إلى اللغة ${LANGS[lang]||lang}:\n\n"${text}"`}]})});const d=await r.json();const rep=d.content?.find(b=>b.type==='text')?.text||'خطأ في الترجمة';setTranslated(rep);setHistory(p=>[{id:Date.now(),original:text,translated:rep,lang:LANGS[lang],date:new Date().toLocaleDateString('ar-SA')},...p.slice(0,9)]);toast('تمت الترجمة ✓','success');}
    catch{setTranslated('خطأ في الترجمة. تحقق من الاتصال.');toast('خطأ في الترجمة','error');}
    setTranslating(false);
  };
  return(<div style={{padding:22,height:'100%',overflowY:'auto'}}>
    <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:20}}><div style={{width:52,height:52,borderRadius:13,background:'linear-gradient(135deg,#6d28d9,#a78bfa)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:24}}>🎙️</div><div><h1 style={{color:'#a78bfa',fontSize:20,fontWeight:900}}>تحويل الصوت إلى نص والترجمة الذكية</h1><p style={{color:'#546e7a',fontSize:13}}>مدعوم بـ Claude AI</p></div></div>
    <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(270px,1fr))',gap:16,marginBottom:16}}>
      <div className="mc"><h3 style={{color:'#a78bfa',fontWeight:800,marginBottom:16,fontSize:14}}>🎙️ التسجيل الصوتي</h3>
        <div style={{display:'flex',flexDirection:'column',alignItems:'center',gap:16}}>
          <button onClick={isRec?stopRec:startRec} style={{width:72,height:72,borderRadius:'50%',border:'none',cursor:'pointer',fontSize:28,background:isRec?'linear-gradient(135deg,#b91c1c,#ef4444)':'linear-gradient(135deg,#0e7490,#38bdf8)',boxShadow:isRec?'none':'0 8px 22px rgba(14,116,144,.4)'}}>{isRec?'⏹️':'🎙️'}</button>
          <div style={{textAlign:'center'}}><div style={{color:isRec?'#ef4444':'#78909c',fontWeight:800,fontSize:13,marginBottom:3}}>{isRec?'🔴 جارٍ التسجيل...':'اضغط للتسجيل'}</div><div style={{color:'#374151',fontSize:12}}>يعمل على Chrome وEdge</div></div>
        </div>
        <div style={{height:1,background:'rgba(255,255,255,.06)',margin:'14px 0'}}/>
        <div style={{marginBottom:12}}><div style={{color:'#94a3b8',fontSize:12,marginBottom:8,fontWeight:600}}>اللغة المستهدفة</div>
          <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:6}}>
            {Object.entries(LANGS).map(([c,l])=>(<button key={c} onClick={()=>setLang(c)} style={{padding:'6px 7px',borderRadius:9,border:`1px solid ${lang===c?'rgba(167,139,250,.5)':'rgba(255,255,255,.06)'}`,background:lang===c?'rgba(167,139,250,.15)':'transparent',color:lang===c?'#a78bfa':'#64748b',cursor:'pointer',fontSize:11,fontFamily:'Tajawal,sans-serif'}}>{['🇺🇸','🇫🇷','🇩🇪','🇪🇸','🇨🇳','🇹🇷','🇮🇱','📝'][['en','fr','de','es','zh','tr','he','ar'].indexOf(c)]} {l}</button>))}
          </div>
        </div>
        <button onClick={doTranslate} disabled={translating||!text.trim()} style={{width:'100%',padding:12,borderRadius:10,border:'none',cursor:translating||!text.trim()?'not-allowed':'pointer',background:'linear-gradient(135deg,#6d28d9,#a78bfa)',color:'#fff',fontWeight:800,fontSize:14,opacity:translating||!text.trim()?.5:1,fontFamily:'Tajawal,sans-serif'}}>{translating?'⏳ جارٍ الترجمة...':'🌐 ترجم الآن'}</button>
      </div>
      <div className="mc"><h3 style={{color:'#a78bfa',fontWeight:800,marginBottom:12,fontSize:14}}>📝 النص والترجمة</h3>
        <div style={{color:'#78909c',fontSize:12,marginBottom:5,fontWeight:600}}>النص الأصلي (عربي)</div>
        <textarea className="inp" rows={4} value={text} onChange={e=>setText(e.target.value)} placeholder="يظهر هنا النص من الصوت، أو اكتب مباشرة..." style={{resize:'vertical',marginBottom:10,lineHeight:1.8}}/>
        <div style={{color:'#78909c',fontSize:12,marginBottom:5,fontWeight:600}}>النص المترجم</div>
        {translating?<div style={{display:'flex',gap:5,alignItems:'center',padding:'14px 0'}}>{[0,1,2,3].map(i=><div key={i} style={{width:8,height:8,borderRadius:'50%',background:'#a78bfa',animation:`wave 1s ease-in-out ${i*0.15}s infinite`}}/>)}<span style={{color:'#546e7a',fontSize:12,marginRight:8}}>جارٍ الترجمة بالذكاء الاصطناعي...</span></div>
        :<textarea className="inp" rows={4} value={translated} readOnly placeholder="يظهر هنا النص المترجم..." style={{resize:'vertical',lineHeight:1.8,opacity:translated?1:.5}}/>}
        {translated&&<button onClick={()=>navigator.clipboard?.writeText(translated).then(()=>toast('تم النسخ ✓','success'))} style={{width:'100%',marginTop:9,padding:'8px',borderRadius:9,border:'1px solid rgba(255,255,255,.1)',background:'transparent',color:'#64748b',cursor:'pointer',fontSize:12,fontFamily:'Tajawal,sans-serif'}}>📋 نسخ الترجمة</button>}
      </div>
    </div>
    {history.length>0&&(<div className="mc"><div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:12}}><h3 style={{color:'#a78bfa',fontWeight:800,fontSize:14}}>🕐 سجل الترجمات ({history.length})</h3><button onClick={()=>setHistory([])} style={{background:'rgba(239,68,68,.1)',border:'1px solid rgba(239,68,68,.2)',borderRadius:7,padding:'4px 10px',cursor:'pointer',color:'#f87171',fontSize:12,fontFamily:'Tajawal,sans-serif'}}>مسح</button></div>
      <div style={{display:'flex',flexDirection:'column',gap:9}}>{history.map(h=>(<div key={h.id} className="mc" style={{padding:'12px 14px'}}><div style={{display:'flex',justifyContent:'space-between',marginBottom:5}}><span style={{background:'rgba(167,139,250,.18)',color:'#a78bfa',borderRadius:12,padding:'2px 8px',fontSize:10,fontWeight:700}}>🌐 {h.lang}</span><span style={{color:'#374151',fontSize:10}}>{h.date}</span></div><div style={{color:'#78909c',fontSize:13,marginBottom:5,lineHeight:1.6}}>{h.original}</div><div style={{color:'#e2e8f0',fontSize:13,lineHeight:1.6,borderRight:'2px solid #a78bfa',paddingRight:9}}>{h.translated}</div></div>))}</div>
    </div>)}
  </div>);
}

