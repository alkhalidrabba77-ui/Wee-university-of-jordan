const cloneTree=n=>({...n,children:(n.children||[]).map(cloneTree)});
const updNode=(t,id,u)=>t.id===id?{...t,...u}:{...t,children:(t.children||[]).map(c=>updNode(c,id,u))};
const delNode=(t,id)=>({...t,children:(t.children||[]).filter(c=>c.id!==id).map(c=>delNode(c,id))});
const addChild=(t,pid,ch)=>t.id===pid?{...t,children:[...(t.children||[]),ch]}:{...t,children:(t.children||[]).map(c=>addChild(c,pid,ch))};
const findNode=(t,id)=>{if(t.id===id)return t;for(const c of(t.children||[])){const f=findNode(c,id);if(f)return f;}return null;};
const flatTree=t=>[t,...(t.children||[]).flatMap(flatTree)];
