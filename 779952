  return(
    <div style={{padding:22,height:'100%',overflowY:'auto'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:20,flexWrap:'wrap',gap:12}}>
        <div><h1 style={{color:'#38bdf8',fontSize:20,fontWeight:900}}>📲 مواقع التواصل الاجتماعي</h1><p style={{color:'#64748b',fontSize:13}}>إدارة روابط التواصل وتفعيلها</p></div>
        <button className="gb" onClick={()=>setShowAdd(true)} style={{padding:'9px 18px',fontSize:14}}>➕ إضافة منصة</button>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(285px,1fr))',gap:12,marginBottom:22}}>
        {links.map(link=>(
          <div key={link.id} className="mc fiu" style={{border:`1px solid ${link.active?link.color+'40':'rgba(26,122,138,.15)'}`,opacity:link.active?1:.6}}>
            <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:12}}>
              <div style={{width:48,height:48,borderRadius:14,background:`${link.color}18`,border:`2px solid ${link.color}40`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:22,flexShrink:0}}>{link.icon}</div>
              <div style={{flex:1}}>
                <div style={{color:'#e2e8f0',fontWeight:700,fontSize:14}}>{link.platform}</div>
                <a href={link.url} target="_blank" rel="noreferrer" style={{color:link.color,fontSize:11,textDecoration:'none',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap',display:'block',maxWidth:190}}>{link.url}</a>
              </div>
            </div>
            <div style={{display:'flex',gap:8,alignItems:'center'}}>
              <div onClick={()=>setLinks(p=>p.map(l=>l.id===link.id?{...l,active:!l.active}:l))} style={{width:44,height:24,borderRadius:12,background:link.active?link.color:'#1e3a5f',cursor:'pointer',position:'relative',transition:'all .3s',flexShrink:0}}>
                <div style={{width:18,height:18,borderRadius:'50%',background:'#fff',position:'absolute',top:3,right:link.active?3:'auto',left:link.active?'auto':3,transition:'all .3s'}}/>
              </div>
              <span style={{color:link.active?'#22c55e':'#475569',fontSize:12,fontWeight:600,flex:1}}>{link.active?'مُفعَّل':'معطَّل'}</span>
              <button onClick={()=>setEditing({...link})} style={{background:'rgba(56,189,248,.1)',border:'1px solid rgba(56,189,248,.2)',borderRadius:8,padding:'4px 9px',cursor:'pointer',color:'#38bdf8',fontSize:13,fontFamily:'Tajawal,sans-serif'}}>✏️</button>
              <button onClick={()=>{setLinks(p=>p.filter(l=>l.id!==link.id));toast('تم الحذف','error');}} style={{background:'rgba(239,68,68,.1)',border:'1px solid rgba(239,68,68,.2)',borderRadius:8,padding:'4px 9px',cursor:'pointer',color:'#f87171',fontSize:13,fontFamily:'Tajawal,sans-serif'}}>🗑️</button>
              <a href={link.url} target="_blank" rel="noreferrer" style={{background:`${link.color}18`,border:`1px solid ${link.color}40`,borderRadius:8,padding:'4px 9px',cursor:'pointer',color:link.color,fontSize:13,textDecoration:'none'}}>🔗</a>
            </div>
          </div>
        ))}
      </div>
      <div className="gc" style={{padding:18}}>
        <h3 style={{color:'#38bdf8',fontWeight:800,fontSize:14,marginBottom:12}}>📊 إحصائيات</h3>
        <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:10}}>
          {[['إجمالي المنصات',links.length,'📱'],['منصات نشطة',links.filter(l=>l.active).length,'✅'],['منصات معطلة',links.filter(l=>!l.active).length,'⭕']].map(([l,v,e])=>(
            <div key={l} style={{textAlign:'center',background:'rgba(56,189,248,.05)',borderRadius:12,padding:12}}>
              <div style={{fontSize:20}}>{e}</div><div style={{color:'#38bdf8',fontSize:20,fontWeight:900}}>{v}</div><div style={{color:'#64748b',fontSize:11}}>{l}</div>
            </div>
          ))}
        </div>
      </div>
      {showAdd&&(
        <Modal onClose={()=>setShowAdd(false)} title="➕ إضافة منصة">
          <div style={{marginBottom:12}}>
            <label className="lbl">المنصة</label>
            <select className="sel" value={newLink.platform} onChange={e=>{const p=e.target.value;const found=PLATS.find(([n])=>n===p);setNewLink(x=>({...x,platform:p,icon:found?found[1]:'🌐',color:found?found[2]:'#38bdf8'}));}}>
              <option value="">اختر منصة...</option>
              {PLATS.map(([n,e])=><option key={n} value={n}>{e} {n}</option>)}
            </select>
          </div>
          <div style={{marginBottom:14}}>
            <label className="lbl">الرابط (URL)</label>
            <input className="inp" value={newLink.url} onChange={e=>setNewLink(x=>({...x,url:e.target.value}))} placeholder="https://..."/>
          </div>
          <div style={{display:'flex',gap:12}}>
            <button className="gb" onClick={()=>{if(!newLink.platform||!newLink.url)return toast('جميع الحقول مطلوبة','warning');setLinks(p=>[...p,{id:uid(),...newLink,active:true}]);setNewLink({platform:'',url:'',icon:'🌐',color:'#38bdf8'});setShowAdd(false);toast('تمت الإضافة ✓','success');}} style={{flex:1,padding:13}}>إضافة</button>
            <button onClick={()=>setShowAdd(false)} style={{flex:1,padding:13,borderRadius:10,border:'1px solid rgba(255,255,255,.1)',background:'transparent',color:'#94a3b8',cursor:'pointer'}}>إلغاء</button>
          </div>
        </Modal>
      )}
      {editing&&(
        <Modal onClose={()=>setEditing(null)} title="✏️ تعديل الرابط">
          {[['اسم المنصة','platform','text'],['الرابط','url','url']].map(([lbl,k,type])=>(
            <div key={k} style={{marginBottom:12}}>
              <label className="lbl">{lbl}</label>
              <input className="inp" type={type} value={editing[k]} onChange={e=>setEditing(x=>({...x,[k]:e.target.value}))}/>
            </div>
          ))}
          <div style={{display:'flex',gap:12}}>
            <button className="gb" onClick={()=>{setLinks(p=>p.map(l=>l.id===editing.id?editing:l));toast('تم التحديث ✓','success');setEditing(null);}} style={{flex:1,padding:13}}>حفظ</button>
            <button onClick={()=>setEditing(null)} style={{flex:1,padding:13,borderRadius:10,border:'1px solid rgba(255,255,255,.1)',background:'transparent',color:'#94a3b8',cursor:'pointer'}}>إلغاء</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

