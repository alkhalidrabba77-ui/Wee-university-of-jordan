/* ── Toast ── */
function Toast({t,onClose}){
  useEffect(()=>{if(!t)return;const tm=setTimeout(onClose,3800);return()=>clearTimeout(tm);},[t]);
  if(!t)return null;
  const cls={success:'ts',error:'te',info:'ti',warning:'tw'}[t.type]||'ti';
  const e={success:'✅',error:'❌',info:'ℹ️',warning:'⚠️'}[t.type]||'ℹ️';
  return <div className={`toast-wrap ${cls}`}>{e} {t.msg}</div>;
}

/* ── Modal ── */
function Modal({onClose,children,title,maxW=520}){
  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal-box" style={{maxWidth:maxW}} onClick={e=>e.stopPropagation()}>
        {title&&<div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:20}}>
          <h2 style={{color:'#38bdf8',fontSize:18,fontWeight:900}}>{title}</h2>
          <button onClick={onClose} style={{background:'rgba(255,255,255,.07)',border:'none',borderRadius:8,padding:'6px 11px',cursor:'pointer',color:'#94a3b8',fontSize:16}}>✕</button>
        </div>}
        {children}
      </div>
    </div>
  );
}

/* ── OrgCard ── */
function OrgCard({node,onEdit,onDelete,onAdd,onPhoto,onDoc,isRoot}){
  const [hov,setHov]=useState(false);
  const pRef=useRef(),dRef=useRef();
  const lc=LVLMAP[node.level]||LVLMAP.staff;
  const handleP=e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>onPhoto(node.id,ev.target.result);r.readAsDataURL(f);};
  const handleD=e=>{const fs=Array.from(e.target.files);if(!fs.length)return;onDoc(node.id,fs.map(f=>f.name));};
  return(
    <div className="nc" onMouseEnter={()=>setHov(true)} onMouseLeave={()=>setHov(false)}
      style={{background:lc.bg,border:`2px solid ${hov?lc.accent:lc.border}`,borderRadius:16,padding:'14px 16px',minWidth:160,maxWidth:200,textAlign:'center',position:'relative',boxShadow:hov?`0 14px 44px ${lc.border}`:'0 4px 18px rgba(0,0,0,.28)'}}>
      {hov&&<div style={{position:'absolute',top:-40,left:'50%',transform:'translateX(-50%)',display:'flex',gap:5,zIndex:10,background:'rgba(3,11,24,.95)',borderRadius:10,padding:'5px 8px',border:'1px solid rgba(56,189,248,.2)',whiteSpace:'nowrap'}}>
        {[{e:'✏️',fn:()=>onEdit(node),t:'تعديل',bg:'#0e7490'},{e:'📷',fn:()=>pRef.current?.click(),t:'صورة',bg:'#059669'},{e:'📎',fn:()=>dRef.current?.click(),t:'مستند',bg:'#7c3aed'},{e:'➕',fn:()=>onAdd(node),t:'إضافة',bg:'#0e7490'}].map(({e,fn,t,bg},i)=>(
          <button key={i} onClick={fn} title={t} style={{border:'none',borderRadius:7,padding:'4px 8px',cursor:'pointer',color:'#fff',background:bg,fontSize:13}}>{e}</button>
        ))}
        {!isRoot&&<button onClick={()=>onDelete(node)} title="حذف" style={{background:'#dc2626',border:'none',borderRadius:7,padding:'4px 8px',cursor:'pointer',color:'#fff',fontSize:13}}>🗑️</button>}
      </div>}
      <input ref={pRef} type="file" accept="image/*" style={{display:'none'}} onChange={handleP} capture="user"/>
      <input ref={dRef} type="file" multiple style={{display:'none'}} onChange={handleD}/>
      <div style={{display:'flex',justifyContent:'center',marginBottom:8}}>
        <div className="pr-ring" style={{width:56,height:56,cursor:'pointer'}} onClick={()=>pRef.current?.click()}>
          {node.photo?<img src={node.photo} alt={node.name} style={{width:'100%',height:'100%',objectFit:'cover'}}/>
          :<div style={{width:'100%',height:'100%',background:`linear-gradient(135deg,${lc.bg},rgba(0,0,0,.2))`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:22}}>👤</div>}
        </div>
      </div>
      <div style={{display:'flex',justifyContent:'center',marginBottom:5}}><span className={`chip ${lc.cls}`}>{lc.label}</span></div>
      <div style={{color:lc.accent,fontWeight:800,fontSize:11.5,marginBottom:4,lineHeight:1.4}}>{node.role}</div>
      <div style={{color:node.name?'#e2e8f0':'#475569',fontSize:11.5,fontWeight:node.name?600:400}}>{node.name||'لم يُحدَّد بعد'}</div>
      {node.dept&&<div style={{color:'#64748b',fontSize:11,marginTop:2}}>{node.dept}</div>}
      {node.docs?.length>0&&<div style={{marginTop:6}}><span style={{background:'rgba(124,58,237,.25)',color:'#d8b4fe',fontSize:10,padding:'2px 7px',borderRadius:20}}>📎{node.docs.length}</span></div>}
    </div>
  );
}

function OrgTree({node,actions,isRoot=false}){
  const ch=node.children||[];
  return(
    <div style={{display:'flex',flexDirection:'column',alignItems:'center'}}>
      <OrgCard node={node} isRoot={isRoot} {...actions}/>
      {ch.length>0&&<>
        <div style={{width:2,height:24,background:'linear-gradient(to bottom,#38bdf8,rgba(56,189,248,.2))'}}/>
        <div style={{position:'relative',display:'flex',alignItems:'flex-start'}}>
          {ch.length>1&&<div style={{position:'absolute',top:0,left:'8%',right:'8%',height:2,background:'linear-gradient(90deg,rgba(56,189,248,0),#38bdf8,rgba(56,189,248,0))',pointerEvents:'none'}}/>}
          {ch.map(c=>(
            <div key={c.id} style={{display:'flex',flexDirection:'column',alignItems:'center',padding:'0 10px'}}>
              <div style={{width:2,height:24,background:'linear-gradient(to bottom,#38bdf8,rgba(56,189,248,.2))'}}/>
              <OrgTree node={c} actions={actions}/>
            </div>
          ))}
        </div>
      </>}
    </div>
  );
}

/* ── OrgModal ── */
function OrgModal({mode,node,onSave,onClose}){
  const init=mode==='add'?{role:'',name:'',dept:'',level:'staff',email:'',phone:'',notes:''}:{role:node.role,name:node.name,dept:node.dept,level:node.level,email:node.email||'',phone:node.phone||'',notes:node.notes||''};
