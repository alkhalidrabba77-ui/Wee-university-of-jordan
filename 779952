/* ── OrgPage ── */
function OrgPage({org,setOrg,toast}){
  const [modal,setModal]=useState(null);
  const [search,setSearch]=useState('');
  const actions={
    onEdit:n=>setModal({t:'edit',node:n}),
    onDelete:n=>setModal({t:'del',node:n}),
    onAdd:n=>setModal({t:'add',pid:n.id}),
    onPhoto:(id,photo)=>{setOrg(p=>updNode(p,id,{photo}));toast('تم تحديث الصورة ✓','success');},
    onDoc:(id,docs)=>{const nd=findNode(org,id);setOrg(p=>updNode(p,id,{docs:[...(nd?.docs||[]),...docs]}));toast(`تم تحميل ${docs.length} مستند ✓`,'success');},
  };
  const all=flatTree(org);
  return(
    <div style={{padding:22,height:'100%',display:'flex',flexDirection:'column'}}>
      <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14,flexWrap:'wrap',gap:12}}>
        <div>
          <h1 style={{color:'#38bdf8',fontSize:20,fontWeight:900}}>🏢 الهيكل التنظيمي</h1>
          <p style={{color:'#64748b',fontSize:13}}>{all.length} وظيفة • {all.filter(n=>n.name).length} محددة • مرر على البطاقة لخيارات الإدارة</p>
        </div>
        <div style={{display:'flex',gap:10}}>
          <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="🔍 بحث..." style={{background:'rgba(255,255,255,.04)',border:'1px solid rgba(56,189,248,.2)',borderRadius:10,padding:'8px 14px',color:'#e2e8f0',fontSize:13,width:180,fontFamily:'Tajawal,sans-serif'}}/>
          <button className="gb" onClick={()=>setModal({t:'add',pid:org.id})} style={{padding:'9px 18px',fontSize:14}}>➕ إضافة</button>
        </div>
      </div>
      {search&&<div style={{marginBottom:12,display:'flex',gap:8,flexWrap:'wrap'}}>
        {all.filter(n=>n.name?.includes(search)||n.role?.includes(search)).map(n=>(
          <div key={n.id} className="mc" style={{padding:'8px 14px',display:'flex',gap:8,alignItems:'center',flexShrink:0}}>
            <span style={{fontSize:16}}>👤</span>
            <div><div style={{color:'#38bdf8',fontWeight:700,fontSize:13}}>{n.role}</div><div style={{color:'#94a3b8',fontSize:11}}>{n.name||'شاغر'}</div></div>
          </div>
        ))}
      </div>}
      <div style={{flex:1,overflowX:'auto',overflowY:'auto'}}>
        <div style={{minWidth:'max-content',paddingBottom:40,paddingTop:26,paddingLeft:20,paddingRight:20}}>
          <OrgTree node={org} actions={actions} isRoot/>
        </div>
      </div>
      {modal?.t==='add'&&<OrgModal mode="add" onSave={d=>{setOrg(p=>addChild(p,modal.pid,{id:uid(),...d}));toast('تمت الإضافة ✓','success');setModal(null);}} onClose={()=>setModal(null)}/>}
      {modal?.t==='edit'&&<OrgModal mode="edit" node={modal.node} onSave={d=>{setOrg(p=>updNode(p,modal.node.id,d));toast('تم التحديث ✓','success');setModal(null);}} onClose={()=>setModal(null)}/>}
      {modal?.t==='del'&&<Modal onClose={()=>setModal(null)} title="⚠️ تأكيد الحذف">
        <p style={{color:'#94a3b8',fontSize:14,lineHeight:1.9,marginBottom:22}}>هل تريد حذف <strong style={{color:'#f87171'}}>"{modal.node.role}"</strong>؟ سيُحذف المرؤوسون أيضاً.</p>
        <div style={{display:'flex',gap:12}}>
          <button className="rb" onClick={()=>{setOrg(p=>delNode(p,modal.node.id));toast('تم الحذف','error');setModal(null);}} style={{flex:1,padding:13}}>تأكيد الحذف</button>
          <button onClick={()=>setModal(null)} style={{flex:1,padding:13,borderRadius:10,border:'1px solid rgba(255,255,255,.1)',background:'transparent',color:'#94a3b8',cursor:'pointer'}}>إلغاء</button>
        </div>
      </Modal>}
    </div>
  );
}

/* ── Researchers ── */
