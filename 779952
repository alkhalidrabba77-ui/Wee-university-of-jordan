        <div style={{display:'flex',gap:10}}>
          {statusOpts.length>0&&<select className="sel" style={{width:'auto',padding:'8px 12px',fontSize:13}} value={filter} onChange={e=>setFilter(e.target.value)}><option value="all">الكل</option>{statusOpts.map(s=><option key={s} value={s}>{s}</option>)}</select>}
