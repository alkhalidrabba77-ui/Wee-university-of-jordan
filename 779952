              {centerLogo&&<button className="rb" onClick={()=>{setCenterLogo(null);toast('تم حذف الشعار','error');}} style={{padding:'7px 14px',fontSize:12}}>🗑️ حذف</button>}
            </div>
          </div>
          <label className="lbl">اسم المركز</label>
          <input className="inp" value={cName} onChange={e=>setCName(e.target.value)} style={{marginBottom:10}}/>
          <button className="gb" onClick={()=>toast('تم الحفظ ✓','success')} style={{width:'100%',padding:11,fontSize:13}}>حفظ التغييرات</button>
        </div>
        <div className="gc" style={{padding:20}}>
          <h3 style={{color:'#38bdf8',fontWeight:800,marginBottom:14,fontSize:14}}>🔧 إعدادات التطبيق</h3>
          {[['notify','🔔 الإشعارات','استلام إشعارات فورية'],['sound','🔊 الصوت','تشغيل صوت الإشعارات'],['autoSave','💾 الحفظ التلقائي','حفظ التغييرات آلياً'],['compact','📐 العرض المضغوط','محتوى مكثف في مساحة أقل']].map(([k,lbl,desc])=>(
            <div key={k} style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'12px 0',borderBottom:'1px solid rgba(255,255,255,.05)'}}>
              <div><div style={{color:'#e2e8f0',fontSize:13}}>{lbl}</div><div style={{color:'#475569',fontSize:11}}>{desc}</div></div>
              <div onClick={()=>toggle(k)} style={{width:46,height:26,borderRadius:13,background:settings[k]?'#0e7490':'#1e3a5f',cursor:'pointer',position:'relative',transition:'all .3s',flexShrink:0}}>
                <div style={{width:20,height:20,borderRadius:'50%',background:'#fff',position:'absolute',top:3,right:settings[k]?3:'auto',left:settings[k]?'auto':3,transition:'all .3s'}}/>
              </div>
            </div>
          ))}
        </div>
        <div className="gc" style={{padding:20}}>
          <h3 style={{color:'#38bdf8',fontWeight:800,marginBottom:14,fontSize:14}}>ℹ️ معلومات النظام</h3>
          {[['الإصدار','v3.1.0 — نسخة كاملة'],['المنصة','ويب • موبايل • لابتوب'],['اللغة','العربية (RTL)'],['الترخيص','الجامعة الأردنية © 2025'],['آخر تحديث',nowStr()]].map(([k,v])=>(
            <div key={k} style={{display:'flex',justifyContent:'space-between',padding:'9px 0',borderBottom:'1px solid rgba(255,255,255,.04)',fontSize:13}}>
              <span style={{color:'#64748b'}}>{k}</span><span style={{color:'#e2e8f0',fontWeight:600}}>{v}</span>
            </div>
          ))}
          <button className="gb" onClick={()=>toast('تم إنشاء نسخة احتياطية ✓','success')} style={{width:'100%',padding:11,marginTop:14,fontSize:13}}>💾 نسخ احتياطي</button>
        </div>
      </div>
    </div>
  );
