          </div>
        </Modal>
      )}
    </div>
  );
}

/* ── Satisfaction ── */
function SatisfactionPage({toast}){
  const [rating,setRating]=useState(0);
  const [dept,setDept]=useState('');
  const [comment,setComment]=useState('');
  const [results,setResults]=useState([
    {label:'بيئة العمل',score:4.2,count:38},{label:'الراتب والمزايا',score:3.5,count:38},
    {label:'الإدارة والقيادة',score:4.5,count:38},{label:'فرص التطوير',score:3.8,count:38},
    {label:'التواصل الداخلي',score:4.1,count:38},
  ]);
  const [done,setDone]=useState(false);
  const submit=()=>{
    if(!rating)return toast('الرجاء اختيار التقييم','warning');
    setResults(p=>p.map(r=>({...r,score:+((r.score*r.count+rating)/(r.count+1)).toFixed(2),count:r.count+1})));
    setDone(true);toast('شكراً! تم تسجيل رأيك ✓','success');
    setTimeout(()=>{setDone(false);setRating(0);setComment('');},2000);
  };
  return(
    <div style={{padding:22,height:'100%',overflowY:'auto'}}>
      <h1 style={{color:'#38bdf8',fontSize:20,fontWeight:900,marginBottom:6}}>😊 الرضا الوظيفي</h1>
