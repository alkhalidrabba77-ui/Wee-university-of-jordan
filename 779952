      </div>
      <Section title="الرؤية" icon="🌟" field="vision"/>
      <Section title="الرسالة" icon="🎯" field="mission"/>
      <Section title="القيم الأساسية" icon="💎" field="values" isArr/>
      <Section title="الأهداف التشغيلية" icon="📌" field="goals" isArr/>
      <Section title="الأهداف الاستراتيجية" icon="🚀" field="strategic" isArr/>
      {editing&&(
        <Modal onClose={()=>setEditing(null)} title="✏️ تعديل المحتوى" maxW={580}>
          {Array.isArray(content[editing])?(
            <>
              <div style={{display:'flex',flexDirection:'column',gap:8,marginBottom:14}}>
                {content[editing].map((item,i)=>(
                  <div key={i} style={{display:'flex',gap:8}}>
                    <input className="inp" value={item} onChange={e=>{const arr=[...content[editing]];arr[i]=e.target.value;setContent(p=>({...p,[editing]:arr}));}} style={{flex:1}}/>
                    <button onClick={()=>setContent(p=>({...p,[editing]:content[editing].filter((_,j)=>j!==i)}))} style={{background:'rgba(239,68,68,.15)',border:'1px solid rgba(239,68,68,.3)',borderRadius:8,padding:'6px 10px',cursor:'pointer',color:'#f87171',fontFamily:'Tajawal,sans-serif'}}>🗑️</button>
                  </div>
                ))}
              </div>
              <button className="gb" onClick={()=>setContent(p=>({...p,[editing]:[...content[editing],'']})) } style={{width:'100%',padding:10,marginBottom:14,fontSize:13}}>➕ إضافة</button>
            </>
          ):(
            <textarea className="inp" rows={5} value={content[editing]} onChange={e=>setContent(p=>({...p,[editing]:e.target.value}))} style={{resize:'vertical',marginBottom:14}}/>
          )}
          <div style={{display:'flex',gap:12}}>
            <button className="gb" onClick={()=>{toast('تم الحفظ ✓','success');setEditing(null);}} style={{flex:1,padding:13}}>حفظ</button>
            <button onClick={()=>setEditing(null)} style={{flex:1,padding:13,borderRadius:10,border:'1px solid rgba(255,255,255,.1)',background:'transparent',color:'#94a3b8',cursor:'pointer'}}>إلغاء</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

/* ── Social ── */
function SocialPage({toast}){
  const [links,setLinks]=useState(INIT_SOCIAL);
  const [editing,setEditing]=useState(null);
  const [showAdd,setShowAdd]=useState(false);
  const [newLink,setNewLink]=useState({platform:'',url:'',icon:'🌐',color:'#38bdf8'});
