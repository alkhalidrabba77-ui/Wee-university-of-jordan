    <div className="gc" style={{padding:20,marginBottom:14}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:12}}>
        <h3 style={{color:'#38bdf8',fontWeight:900,fontSize:15,display:'flex',alignItems:'center',gap:8}}><span style={{fontSize:20}}>{icon}</span>{title}</h3>
        <button onClick={()=>setEditing(field)} style={{background:'rgba(56,189,248,.1)',border:'1px solid rgba(56,189,248,.25)',borderRadius:8,padding:'4px 11px',cursor:'pointer',color:'#38bdf8',fontSize:12,fontFamily:'Tajawal,sans-serif'}}>✏️ تعديل</button>
      </div>
      {isArr?<div style={{display:'flex',flexDirection:'column',gap:7}}>
        {content[field].map((item,i)=>(
          <div key={i} style={{display:'flex',alignItems:'flex-start',gap:10,padding:'9px 12px',background:'rgba(56,189,248,.04)',borderRadius:10,border:'1px solid rgba(56,189,248,.1)'}}>
            <span style={{color:'#38bdf8',fontWeight:900,fontSize:13,flexShrink:0}}>{i+1}.</span>
            <span style={{color:'#e2e8f0',fontSize:13,lineHeight:1.7}}>{item}</span>
          </div>
        ))}
      </div>:<p style={{color:'#e2e8f0',fontSize:13.5,lineHeight:2,borderRight:'3px solid #0e7490',paddingRight:14}}>{content[field]}</p>}
    </div>
