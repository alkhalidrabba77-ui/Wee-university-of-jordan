  'default':'شكراً لتواصلك مع المساعد الذكي لمركز المياه والبيئة والطاقة! للحصول على إجابة دقيقة، يُرجى التواصل المباشر مع إدارة المركز عبر البريد الإلكتروني الرسمي أو زيارة مقر المركز في الجامعة الأردنية. 💧🌿⚡'
};
const getBotReply=q=>{const lq=q;for(const[k,v]of Object.entries(BOT_REPLIES)){if(k!=='default'&&lq.includes(k))return v;}return BOT_REPLIES.default;};

function ChatbotPage({toast}){
  const [msgs,setMsgs]=useState([{id:1,role:'bot',text:'مرحباً! أنا واتر بوت، المساعد الذكي لمركز المياه والبيئة والطاقة في الجامعة الأردنية. كيف يمكنني مساعدتك اليوم؟ 💧🌿⚡'}]);
  const [input,setInput]=useState('');
  const [loading,setLoading]=useState(false);
  const endRef=useRef();
  const SUGGESTED=['ما هي خدمات المركز؟','من هو مدير المركز؟','ما ساعات العمل؟','كيف أتواصل مع الباحثين؟','ما هي أبحاث المركز؟','كيف أقدم شكوى؟'];
  useEffect(()=>{endRef.current?.scrollIntoView({behavior:'smooth'});},[msgs]);
  const send=async(text=input)=>{
    const q=(text||'').trim();
    if(!q||loading)return;
    setInput('');
    const uMsg={id:Date.now(),role:'user',text:q};
    setMsgs(p=>[...p,uMsg]);
    aiInsert(q,true);
    setLoading(true);
    try{
      const hist=msgs.slice(-6).map(m=>({role:m.role==='user'?'user':'assistant',content:m.text}));
      const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:900,system:'أنت المساعد الذكي الرسمي لمركز المياه والبيئة والطاقة في الجامعة الأردنية. اسمك واتر بوت. مدير المركز: أ.د. خلدون شطناوي. رئيس شعبة الباحثين: د. خالد رباع. أجب باللغة العربية بأسلوب ودي ومهني ومختصر.',messages:[...hist,{role:'user',content:q}]})});
      const d=await res.json();
      const reply=d.content?.find(b=>b.type==='text')?.text||'عذراً، لم أتمكن من الرد الآن.';
      setMsgs(p=>[...p,{id:Date.now()+1,role:'bot',text:reply}]);
      aiInsert(reply,false);
    }catch{
      const fallback=getBotReply(q);
      setMsgs(p=>[...p,{id:Date.now()+1,role:'bot',text:fallback}]);
      aiInsert(fallback,false);
    }
    setLoading(false);
  };
  return(
    <div style={{padding:'16px 22px',height:'100%',display:'flex',flexDirection:'column',gap:12}}>
      <div style={{display:'flex',alignItems:'center',gap:12}}>
        <div style={{width:48,height:48,borderRadius:14,background:'linear-gradient(135deg,#0e7490,#38bdf8)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:22,flexShrink:0}}>🤖</div>
        <div>
          <h1 style={{color:'#38bdf8',fontSize:18,fontWeight:900}}>واتر بوت — المساعد الذكي</h1>
          <p style={{color:'#22c55e',fontSize:12}}>● متصل الآن • مركز المياه والبيئة والطاقة</p>
        </div>
      </div>
      <div style={{display:'flex',gap:7,flexWrap:'wrap'}}>
        {SUGGESTED.map(s=>(
          <button key={s} onClick={()=>send(s)} style={{background:'rgba(56,189,248,.08)',border:'1px solid rgba(56,189,248,.2)',borderRadius:20,padding:'5px 11px',cursor:'pointer',color:'#38bdf8',fontSize:11.5,transition:'all .2s',fontFamily:'Tajawal,sans-serif'}}>{s}</button>
        ))}
      </div>
      <div style={{flex:1,overflowY:'auto',display:'flex',flexDirection:'column',gap:11,padding:'4px 0'}}>
        {msgs.map(m=>(
          <div key={m.id} className="fiu" style={{display:'flex',alignItems:'flex-end',gap:9,flexDirection:m.role==='user'?'row-reverse':'row'}}>
            <div style={{width:30,height:30,borderRadius:'50%',background:m.role==='user'?'linear-gradient(135deg,#0e7490,#38bdf8)':'linear-gradient(135deg,#1e3a5f,#0d2a40)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:14,flexShrink:0}}>
              {m.role==='user'?'👤':'🤖'}
            </div>
            <div className={m.role==='user'?'cbu':'cbb'}>{m.text}</div>
          </div>
        ))}
        {loading&&<div style={{display:'flex',gap:9,alignItems:'flex-end'}}>
          <div style={{width:30,height:30,borderRadius:'50%',background:'linear-gradient(135deg,#1e3a5f,#0d2a40)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:14}}>🤖</div>
          <div className="cbb" style={{display:'flex',gap:5,alignItems:'center',padding:'13px 16px'}}>
            {[0,1,2].map(i=><div key={i} style={{width:7,height:7,borderRadius:'50%',background:'#38bdf8',animation:`wv 1s ease-in-out ${i*0.2}s infinite`}}/>)}
          </div>
        </div>}
        <div ref={endRef}/>
      </div>
      <div style={{display:'flex',gap:9}}>
        <input className="inp" value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==='Enter'&&send()} placeholder="اكتب سؤالك هنا..." style={{flex:1}}/>
        <button className="gb" onClick={()=>send()} disabled={loading||!input.trim()} style={{padding:'10px 18px',flexShrink:0,opacity:loading||!input.trim()?.5:1}}>إرسال ↑</button>
        <button onClick={()=>{setMsgs([{id:Date.now(),role:'bot',text:'تم بدء محادثة جديدة. كيف يمكنني مساعدتك؟ 💧'}]);toast('محادثة جديدة ✓','info');}} style={{background:'rgba(255,255,255,.05)',border:'1px solid rgba(255,255,255,.1)',borderRadius:10,padding:'10px 13px',cursor:'pointer',color:'#64748b',flexShrink:0,fontFamily:'Tajawal,sans-serif'}} title="محادثة جديدة">🔄</button>
      </div>
    </div>
  );
}

