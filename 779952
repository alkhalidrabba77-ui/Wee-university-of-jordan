        </div>
      </div>
      <div style={{flex:1,overflowY:'auto',display:'flex',flexDirection:'column',gap:9}}>
        {filtered.length===0&&<div style={{textAlign:'center',color:'#475569',marginTop:60,fontSize:32}}>📭<div style={{fontSize:13,marginTop:12}}>لا توجد عناصر بعد</div></div>}
        {filtered.map(item=>(
          <div key={item.id} className="mc fiu" style={{display:'flex',gap:14,alignItems:'flex-start'}}>
            <div style={{flex:1}}>
              <div style={{display:'flex',alignItems:'center',gap:9,marginBottom:6,flexWrap:'wrap'}}>
                <span style={{color:'#e2e8f0',fontWeight:700,fontSize:14}}>{item.title||item.name||'—'}</span>
                {item.status&&<span style={{background:`${SC[item.status]||'#64748b'}20`,color:SC[item.status]||'#64748b',border:`1px solid ${SC[item.status]||'#64748b'}40`,borderRadius:20,padding:'2px 9px',fontSize:11,fontWeight:700}}>{item.status}</span>}
                {item.priority&&<span style={{background:item.priority==='عاجل'?'rgba(239,68,68,.2)':item.priority==='متوسط'?'rgba(245,158,11,.2)':'rgba(34,197,94,.2)',color:item.priority==='عاجل'?'#f87171':item.priority==='متوسط'?'#fcd34d':'#86efac',borderRadius:20,padding:'2px 9px',fontSize:11,fontWeight:700}}>{item.priority}</span>}
              </div>
              {item.desc&&<p style={{color:'#94a3b8',fontSize:13,lineHeight:1.7}}>{item.desc}</p>}
              <div style={{color:'#475569',fontSize:11,marginTop:5}}>📅 {item.date}</div>
            </div>
            <div style={{display:'flex',gap:6,flexDirection:'column',alignItems:'flex-end'}}>
              {statusOpts.length>0&&<select className="sel" style={{width:'auto',padding:'5px 9px',fontSize:12}} value={item.status} onChange={e=>setItems(p=>p.map(i=>i.id===item.id?{...i,status:e.target.value}:i))}>{statusOpts.map(s=><option key={s} value={s}>{s}</option>)}</select>}
              <button onClick={()=>setItems(p=>p.filter(i=>i.id!==item.id))} style={{background:'rgba(239,68,68,.15)',border:'1px solid rgba(239,68,68,.25)',borderRadius:8,padding:'5px 9px',cursor:'pointer',color:'#f87171',fontSize:13,fontFamily:'Tajawal,sans-serif'}}>🗑️</button>
            </div>
          </div>
        ))}
      </div>
      {show&&(
        <Modal onClose={()=>setShow(false)} title={`➕ ${title}`}>
          {fields.map(f=>(
            <div key={f.key} style={{marginBottom:13}}>
              <label className="lbl">{f.label}{f.req?' *':''}</label>
              {f.type==='textarea'?<textarea className="inp" rows={3} value={form[f.key]||''} onChange={e=>set(f.key,e.target.value)} placeholder={f.label} style={{resize:'vertical'}}/>
