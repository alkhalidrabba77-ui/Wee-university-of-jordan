        <div className="gc" style={{padding:20}}>
          <h3 style={{color:'#e2e8f0',fontWeight:800,marginBottom:16,fontSize:14}}>📋 تقديم تقييم جديد</h3>
          <label className="lbl">القسم</label>
          <select className="sel" style={{marginBottom:12}} value={dept} onChange={e=>setDept(e.target.value)}>
            <option value="">اختر قسمك...</option>
            {['الإدارة','شعبة الباحثين','شعبة الدعم الفني','الديوان','المختبر'].map(d=><option key={d} value={d}>{d}</option>)}
          </select>
          <label className="lbl">التقييم العام</label>
          <div style={{display:'flex',gap:10,justifyContent:'center',marginBottom:14}}>
            {[1,2,3,4,5].map(s=><span key={s} onClick={()=>setRating(s)} style={{fontSize:30,cursor:'pointer',color:s<=rating?'#f59e0b':'#334155',transition:'all .15s'}}>★</span>)}
          </div>
          <textarea className="inp" rows={2} value={comment} onChange={e=>setComment(e.target.value)} placeholder="ملاحظاتك..." style={{marginBottom:12,resize:'vertical'}}/>
          <button className="gb" onClick={submit} style={{width:'100%',padding:12,fontSize:14}}>{done?'✅ تم الإرسال!':'إرسال التقييم'}</button>
        </div>
        <div className="gc" style={{padding:20}}>
          <h3 style={{color:'#e2e8f0',fontWeight:800,marginBottom:16,fontSize:14}}>📊 نتائج الاستطلاع</h3>
          {results.map(r=>(
            <div key={r.label} style={{marginBottom:12}}>
              <div style={{display:'flex',justifyContent:'space-between',marginBottom:4}}>
                <span style={{color:'#e2e8f0',fontSize:13,fontWeight:600}}>{r.label}</span>
                <span style={{color:'#38bdf8',fontWeight:900}}>{r.score.toFixed(1)}/5</span>
              </div>
              <div className="pb"><div className="pf" style={{width:`${(r.score/5)*100}%`,background:'linear-gradient(90deg,#0e7490,#38bdf8)'}}/></div>
            </div>
          ))}
          <div style={{marginTop:14,padding:'12px',background:'rgba(56,189,248,.07)',borderRadius:10,border:'1px solid rgba(56,189,248,.15)',textAlign:'center'}}>
            <div style={{color:'#38bdf8',fontSize:22,fontWeight:900}}>{(results.reduce((a,r)=>a+r.score,0)/results.length).toFixed(1)}</div>
