function VoicePage({toast}){
  const [isRec,setIsRec]=useState(false);
  const [text,setText]=useState('');
  const [translated,setTranslated]=useState('');
  const [lang,setLang]=useState('en');
  const [translating,setTranslating]=useState(false);
  const [history,setHistory]=useState([]);
  const recRef=useRef();
  const startRec=()=>{
    if(!('webkitSpeechRecognition' in window)&&!('SpeechRecognition' in window))return toast('استخدم Chrome أو Edge للتسجيل الصوتي','warning');
    const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    const r=new SR();r.lang='ar-JO';r.continuous=true;r.interimResults=true;
    r.onresult=e=>{let f='';for(let i=e.resultIndex;i<e.results.length;i++)if(e.results[i].isFinal)f+=e.results[i][0].transcript;if(f)setText(p=>p+(p?' ':'')+f);};
    r.onerror=()=>{setIsRec(false);toast('خطأ في التسجيل','error');};
    r.onend=()=>setIsRec(false);
    r.start();recRef.current=r;setIsRec(true);toast('🎙️ جارٍ التسجيل — تكلم الآن','info');
  };
  const stopRec=()=>{recRef.current?.stop();setIsRec(false);toast('تم إيقاف التسجيل ✓','success');};
  const LANGS={en:'الإنجليزية',fr:'الفرنسية',de:'الألمانية',es:'الإسبانية',zh:'الصينية',tr:'التركية',he:'العبرية',ar:'عربية فصحى'};
  const doTranslate=async()=>{
    if(!text.trim())return toast('أدخل نصاً أولاً','warning');
    setTranslating(true);setTranslated('');
    try{const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:800,system:'أنت مترجم محترف. قدم الترجمة مباشرة دون مقدمات.',messages:[{role:'user',content:`ترجم النص التالي إلى اللغة ${LANGS[lang]||lang}:\n\n"${text}"`}]})});const d=await r.json();const rep=d.content?.find(b=>b.type==='text')?.text||'خطأ في الترجمة';setTranslated(rep);setHistory(p=>[{id:Date.now(),original:text,translated:rep,lang:LANGS[lang],date:new Date().toLocaleDateString('ar-SA')},...p.slice(0,9)]);toast('تمت الترجمة ✓','success');}
    catch{setTranslated('خطأ في الترجمة. تحقق من الاتصال.');toast('خطأ في الترجمة','error');}
    setTranslating(false);
  };
  return(<div style={{padding:22,height:'100%',overflowY:'auto'}}>
    <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:20}}><div style={{width:52,height:52,borderRadius:13,background:'linear-gradient(135deg,#6d28d9,#a78bfa)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:24}}>🎙️</div><div><h1 style={{color:'#a78bfa',fontSize:20,fontWeight:900}}>تحويل الصوت إلى نص والترجمة الذكية</h1><p style={{color:'#546e7a',fontSize:13}}>مدعوم بـ Claude AI</p></div></div>
    <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(270px,1fr))',gap:16,marginBottom:16}}>
      <div className="mc"><h3 style={{color:'#a78bfa',fontWeight:800,marginBottom:16,fontSize:14}}>🎙️ التسجيل الصوتي</h3>
